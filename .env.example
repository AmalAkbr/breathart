
# Breath Art Institute Backend - Environment Variables

# ============================================
# SERVER CONFIGURATION
# ============================================

# ===== MONGODB =====
MONGODB_URI=mongodb://localhost:27017/breathart
MONGODB_DB_NAME=breathart

# ===== CLOUDFLARE R2 =====
CLOUDFLARE_R2_BUCKET=breathartinstitute-videos
CLOUDFLARE_R2_ACCOUNT_ID=your_key
CLOUDFLARE_R2_ACCESS_KEY_ID=your_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_key
CLOUDFLARE_R2_PUBLIC_URL=your_key


# ===== IMAGEKIT =====
IMAGEKIT_PUBLIC_KEY=your_key
IMAGEKIT_PRIVATE_KEY=your_key
IMAGEKIT_URL_ENDPOINT=your_key

# ===== SERVER CONFIG =====
PORT=3001
NODE_ENV=development
# NOTE: In development, backend accepts any localhost port automatically
# In production, set this to your exact frontend URL
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_API_URL=http://localhost:3001/api

# ===== JWT & TOKENS =====
JWT_SECRET=ZCBrKcfW0a6OQpToZ5pUXTRVHNBzKxvy+4JGFD64FGKRmqRPQBOWWElpaN8q0QDrn3SUolVGz66Jptt1yLXhcw==
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=7d
