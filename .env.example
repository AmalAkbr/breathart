# ===== EMAIL (NODEMAILER) =====
# Using Gmail or other SMTP service
EMAIL_SERVICE=gmail
EMAIL_USER=yourKey
EMAIL_PASSWORD=yourKey
FROM_EMAIL=noreply@breathart.com
SUPPORT_EMAIL=support@breathart.com
FROM_EMAIL=noreply@breathart.com


# ============================================
# IMAGE CONVERSION & CLEANUP JOBS
# ============================================

# Enable/Disable cleanup cron job
# Set to "false" to disable automatic cleanup
ENABLE_CLEANUP_CRON=true

# Cron schedule for cleanup job (format: "minute hour day-of-month month day-of-week")
# "0 2 * * *" = Every day at 2:00 AM
# "0 */6 * * *" = Every 6 hours
# "0 0 * * 0" = Every Sunday at midnight
CLEANUP_CRON_SCHEDULE=0 2 * * *

# Hours to keep temporary files (default: 24 hours)
# Temp files older than this will be deleted by cleanup job
TEMP_RETENTION_HOURS=24

# Hours to keep uploaded files in local storage (default: 24 hours)
# Files older than this will be deleted by cleanup job
# NOTE: Only local files are deleted, ImageKit URLs are unaffected
UPLOAD_RETENTION_HOURS=24

#this wll be used to clean up orphan videos in R2 that are not associated with any video document in MongoDB. 
#It runs every 12 hours by default, but can be disabled or rescheduled as needed.
ENABLE_ORPHAN_VIDEO_CLEANUP_CRON=true
ORPHAN_VIDEO_CLEANUP_CRON_SCHEDULE=0 */12 * * *

# +++++++++++++++++++++++++++++++++++++
# +++++++++++++++++++++++++++++++++++++
# +++++++++++++++++++++++++++++++++++++

# for frontend .env.local

# ============================================
# SERVER CONFIGURATION frontend
# ============================================

VITE_WEB3FORMS_KEY=your_key

VITE_API_URL=http://localhost:3001/api

JWT_MAX_AGE=7d
VERIFICATION_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=5hr
VITE_NODE_ENV=development
