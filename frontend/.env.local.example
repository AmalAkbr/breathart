# Frontend Environment Configuration Example
# Copy to .env.local and fill in your actual values

# ============================================
# BACKEND API
# ============================================
# MongoDB backend API endpoint
# Development: http://localhost:3001/api
# Production: https://api.yourdomain.com/api
VITE_API_URL=http://localhost:3001/api

# ============================================
# OPTIONAL - Contact Form Submission
# ============================================
# Web3Forms key for contact form (optional)
VITE_WEB3FORMS_KEY=your_web3forms_key_here

# ============================================
# REMOVED SERVICES (No longer used)
# ============================================
# Supabase - Removed (using MongoDB + JWT authentication now)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
