# Breath Art Institute Backend - Environment Variables

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Backend API URL (optional - for documentation/email templates)
BACKEND_API_URL=http://localhost:3001/api

# ============================================
# MONGODB
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/breathart?retryWrites=true&w=majority
MONGODB_DB_NAME=breathart

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# ============================================
# EMAIL SERVICE (Gmail/SendGrid/etc)
# ============================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@breathart.in
SUPPORT_EMAIL=support@breathart.in

# ============================================
# IMAGEKIT (Image Upload & CDN)
# ============================================
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint.imagekit.io

# ============================================
# CLOUDFLARE R2 (Optional - Alternative to ImageKit)
# ============================================
CLOUDFLARE_R2_BUCKET=your-bucket-name
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.example.com

# ============================================
# IMAGE CONVERSION & CLEANUP JOBS
# ============================================

# Enable/Disable cleanup cron job
# Set to "false" to disable automatic cleanup
ENABLE_CLEANUP_CRON=true

# Cron schedule for cleanup job (format: "minute hour day-of-month month day-of-week")
# "0 2 * * *" = Every day at 2:00 AM
# "0 */6 * * *" = Every 6 hours
# "0 0 * * 0" = Every Sunday at midnight
CLEANUP_CRON_SCHEDULE=0 2 * * *

# Hours to keep temporary files (default: 24 hours)
# Temp files older than this will be deleted by cleanup job
TEMP_RETENTION_HOURS=24

# Hours to keep uploaded files in local storage (default: 72 hours)
# Files older than this will be deleted by cleanup job
# NOTE: Only local files are deleted, ImageKit URLs are unaffected
UPLOAD_RETENTION_HOURS=72
